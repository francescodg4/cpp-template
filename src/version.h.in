#ifndef APPLICATION_VERSION_H
#define APPLICATION_VERSION_H

#define APPLICATION_VERSION_MAJOR ${CMAKE_PROJECT_VERSION_MAJOR}
#define APPLICATION_VERSION_MINOR ${CMAKE_PROJECT_VERSION_MINOR}
#define APPLICATION_VERSION_PATCH ${CMAKE_PROJECT_VERSION_PATCH}

#define __STR(x) #x
#define STR(x) __STR(x)

#define APPLICATION_VERSION_STR STR(APPLICATION_VERSION_MAJOR) "." STR(APPLICATION_VERSION_MINOR) "." STR(APPLICATION_VERSION_PATCH)

#endif /* APPLICATION_VERSION_H */
